NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Recommended for Teller sync writes so RLS does not block token,
# account, or transaction persistence.
SUPABASE_SERVICE_ROLE_KEY=

# Teller Connect. Sandbox can run without certificate/key material.
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=sandbox

# Required for Teller development/production API calls that access user data.
# Values may be PEM text with escaped newlines or paths to PEM files.
TELLER_CERTIFICATE=
TELLER_PRIVATE_KEY=

# Local-only test helper. Inserts mock Teller data when calling
# POST /api/teller/mock-sync. Keep false in normal use.
TELLER_ENABLE_MOCK_SYNC=false
