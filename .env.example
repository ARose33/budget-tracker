NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://budget-tracker-beta-bice.vercel.app

# Server-only. Recommended for Plaid sync writes so RLS does not block token,
# account, or transaction persistence.
SUPABASE_SERVICE_ROLE_KEY=

# One-time helper for assigning existing pre-auth rows to the logged-in user.
# Set true only while running POST /api/auth/claim-legacy-data, then turn off.
ALLOW_LEGACY_DATA_CLAIM=false

# Plaid Link and Transactions Sync.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional. If set, the Plaid webhook URL includes this value as a query
# secret and the webhook route will reject requests without it.
PLAID_WEBHOOK_SECRET=

# Shared secret for scheduled Plaid sync calls. Vercel Cron can use CRON_SECRET
# instead; this app accepts either variable.
PLAID_SYNC_CRON_SECRET=
